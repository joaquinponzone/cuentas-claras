{
  "name": "@cuentas-claras/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test --env-file .env",
    "test:watch": "bun test --watch --env-file .env",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun --env-file .env drizzle-kit generate",
    "db:migrate": "bun --env-file .env drizzle-kit push",
    "db:seed": "bun --env-file .env src/db/seed.ts",
    "db:seed:test": "bun --env-file .env src/db/seed-test-data.ts",
    "db:seed:test:clean": "bun --env-file .env src/db/seed-test-data-clean.ts",
    "db:studio": "bun --env-file .env drizzle-kit studio"
  },
  "dependencies": {
    "@cuentas-claras/shared": "workspace:*",
    "@hono/zod-validator": "0.7.6",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "0.45.1",
    "hono": "4.12.5",
    "jose": "6.2.0",
    "postgres": "3.4.8",
    "winston": "3.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "1.3.10",
    "drizzle-kit": "0.31.9",
    "typescript": "^5.8.0"
  }
}
